<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <title>Brackets Report</title>
    <style>
      * {
        box-sizing: border-box;
      }

      @page {
        size: A4;
        margin: 18mm 12mm 16mm;
      }

      body {
        margin: 0;
        font-family: Arial, Helvetica, sans-serif;
        color: #111;
        font-size: 11px;
        background: #fff;
      }

      .page {
        page-break-after: always;
      }

      .page:last-child {
        page-break-after: auto;
      }

      .header {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        margin-bottom: 16px;
        border-bottom: 1px solid #d6d6d6;
        padding-bottom: 10px;
      }

      .brand {
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }

      .event-title {
        text-align: center;
        font-size: 20px;
        font-weight: 700;
      }

      .header-right {
        text-align: right;
        font-size: 10px;
        color: #555;
      }

      .category-title {
        font-size: 18px;
        font-weight: 700;
        margin-bottom: 4px;
      }

      .category-meta {
        font-size: 11px;
        color: #4f4f4f;
        margin-bottom: 14px;
      }

      .section-title {
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        margin: 0 0 8px;
      }

      .athletes-table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 18px;
      }

      .athletes-table th,
      .athletes-table td {
        border: 1px solid #e5e5e5;
        padding: 6px 8px;
        text-align: left;
        vertical-align: top;
      }

      .athletes-table th {
        background: #f4f4f4;
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.03em;
      }

      .bracket-heading {
        text-align: center;
        font-weight: 700;
        font-size: 13px;
        margin: 8px 0 12px;
      }

      .semis-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 18px;
        margin-bottom: 16px;
      }

      .fight-card {
        border: 1px solid #000;
      }

      .fight-title {
        text-align: center;
        font-weight: 700;
        padding: 6px 8px 4px;
        font-size: 12px;
      }

      .fight-lines {
        border-top: 1px solid #000;
      }

      .fight-line,
      .fight-vs {
        min-height: 38px;
        padding: 10px 12px;
        border-top: 1px solid #000;
      }

      .fight-line:first-child,
      .fight-vs:first-child {
        border-top: 0;
      }

      .fight-vs {
        text-align: center;
        font-weight: 700;
        min-height: 26px;
        padding: 6px 12px;
      }

      .fight-athlete {
        font-weight: 600;
      }

      .fight-meta {
        margin-top: 4px;
        font-size: 10px;
        color: #505050;
      }

      .placeholder {
        color: #6b6b6b;
        font-style: italic;
      }

      .single-card {
        margin-bottom: 16px;
      }

      .podium {
        margin-top: 18px;
      }

      .podium-line {
        text-align: center;
        margin: 7px 0;
        font-size: 12px;
      }

      .generated-fights {
        margin-top: 16px;
      }

      .fights-table {
        width: 100%;
        border-collapse: collapse;
      }

      .fights-table th,
      .fights-table td {
        border: 1px solid #d8d8d8;
        padding: 6px 7px;
        text-align: left;
        vertical-align: top;
      }

      .fights-table th {
        background: #f4f4f4;
        font-size: 10px;
        text-transform: uppercase;
      }

      .footer-text {
        margin-top: 14px;
        font-size: 10px;
        color: #555;
      }

      .empty {
        border: 1px dashed #aaa;
        padding: 18px;
        text-align: center;
        color: #666;
      }
    </style>
  </head>
  <body>
    {{#if hasBrackets}}
      {{#each brackets}}
        <section class="page">
          <header class="header">
            <div class="brand">Relatório de Chaves</div>
            <div class="event-title">{{../competitionName}}</div>
            <div class="header-right">
              <div>{{../competitionMode}}</div>
              <div>{{../exportedAt}}</div>
            </div>
          </header>

          <div class="category-title">{{categoryName}}</div>
          <div class="category-meta">
            Chave: {{bracketName}} • Total de atletas: {{athletes.length}}
          </div>

          <h2 class="section-title">Atletas</h2>
          <table class="athletes-table">
            <thead>
              <tr>
                <th>#</th>
                <th>Nome</th>
                <th>Academia</th>
                <th>Nascimento</th>
                <th>Faixa</th>
              </tr>
            </thead>
            <tbody>
              {{#each athletes}}
                <tr>
                  <td>{{id}}</td>
                  <td>{{fullName}}</td>
                  <td>{{academyName}}</td>
                  <td>{{birthDate}}</td>
                  <td>{{belt}}</td>
                </tr>
              {{/each}}
            </tbody>
          </table>

          {{#if stage.semiFinals.length}}
            <div class="bracket-heading">SEMIFINAIS</div>
            <div class="semis-grid">
              {{#each stage.semiFinals}}
                <div class="fight-card">
                  <div class="fight-title">{{label}}</div>
                  <div class="fight-lines">
                    <div class="fight-line">
                      <div class="fight-athlete">{{athleteA}}</div>
                    </div>
                    <div class="fight-vs">VS</div>
                    <div class="fight-line">
                      <div class="fight-athlete">{{athleteB}}</div>
                      {{#if areaName}}
                        <div class="fight-meta">Área: {{areaName}}</div>
                      {{/if}}
                      {{#if winner}}
                        <div class="fight-meta">Vencedor: {{winner}}{{#if winType}} | {{winType}}{{/if}}</div>
                      {{/if}}
                    </div>
                  </div>
                </div>
              {{/each}}
            </div>
          {{/if}}

          <div class="fight-card single-card">
            <div class="fight-title">{{stage.final.label}}</div>
            <div class="fight-lines">
              <div class="fight-line">
                <div class="fight-athlete">{{stage.final.athleteA}}</div>
              </div>
              <div class="fight-vs">VS</div>
              <div class="fight-line">
                <div class="fight-athlete">{{stage.final.athleteB}}</div>
                {{#if stage.final.areaName}}
                  <div class="fight-meta">Área: {{stage.final.areaName}}</div>
                {{/if}}
                {{#if stage.final.winner}}
                  <div class="fight-meta">Vencedor: {{stage.final.winner}}{{#if stage.final.winType}} | {{stage.final.winType}}{{/if}}</div>
                {{else}}
                  <div class="fight-meta placeholder">Campo para preenchimento manual</div>
                {{/if}}
              </div>
            </div>
          </div>

          <div class="fight-card single-card">
            <div class="fight-title">Disputa do 3º lugar</div>
            <div class="fight-lines">
              <div class="fight-line">
                <div class="fight-athlete">Eliminado Luta 1</div>
              </div>
              <div class="fight-vs">VS</div>
              <div class="fight-line">
                <div class="fight-athlete">Eliminado Luta 2</div>
              </div>
            </div>
          </div>

          <div class="podium">
            <div class="podium-line">1: _________________________________</div>
            <div class="podium-line">2: _________________________________</div>
            <div class="podium-line">3: _________________________________</div>
            <div class="podium-line">4: _________________________________</div>
          </div>

          <div class="generated-fights">
            <h2 class="section-title">Lutas Geradas</h2>
            {{#if fights.length}}
              <table class="fights-table">
                <thead>
                  <tr>
                    <th>Round</th>
                    <th>#</th>
                    <th>Atleta A</th>
                    <th>Atleta B</th>
                    <th>Área</th>
                    {{#if ../includeResults}}
                      <th>Vencedor</th>
                      <th>Tipo</th>
                    {{/if}}
                  </tr>
                </thead>
                <tbody>
                  {{#each fights}}
                    <tr>
                      <td>{{round}}</td>
                      <td>{{fightNumber}}</td>
                      <td>{{athleteA}}{{#if academyA}}<br />{{academyA}}{{/if}}</td>
                      <td>{{athleteB}}{{#if academyB}}<br />{{academyB}}{{/if}}</td>
                      <td>{{areaName}}</td>
                      {{#if ../../includeResults}}
                        <td>{{winner}}</td>
                        <td>{{winType}}</td>
                      {{/if}}
                    </tr>
                  {{/each}}
                </tbody>
              </table>
            {{else}}
              <div class="empty">Nenhuma luta gerada para esta chave.</div>
            {{/if}}
          </div>

          <div class="footer-text">Total de atletas: {{athletes.length}}</div>
        </section>
      {{/each}}
    {{else}}
      <section class="page">
        <header class="header">
          <div class="brand">Relatório de Chaves</div>
          <div class="event-title">{{competitionName}}</div>
          <div class="header-right">
            <div>{{competitionMode}}</div>
            <div>{{exportedAt}}</div>
          </div>
        </header>
        <div class="empty">Nenhuma chave encontrada para os filtros informados.</div>
      </section>
    {{/if}}
  </body>
</html>
