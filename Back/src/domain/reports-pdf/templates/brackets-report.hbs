<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <title>Brackets Report</title>
    <style>
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: Arial, Helvetica, sans-serif;
        color: #111827;
        font-size: 12px;
        background: #ffffff;
      }
      .page {
        page-break-after: always;
        min-height: 277mm;
        display: flex;
        flex-direction: column;
        gap: 14px;
      }
      .page:last-child { page-break-after: auto; }
      .header {
        border-bottom: 2px solid #111827;
        padding-bottom: 8px;
      }
      .title {
        font-size: 22px;
        font-weight: 700;
        margin-bottom: 6px;
      }
      .meta {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        color: #4b5563;
      }
      .section-title {
        font-size: 14px;
        font-weight: 700;
        text-transform: uppercase;
        margin-bottom: 6px;
      }
      .summary {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
      }
      .box {
        border: 1px solid #d1d5db;
        border-radius: 8px;
        padding: 10px;
      }
      .athlete-list {
        margin: 0;
        padding: 0;
        list-style: none;
      }
      .athlete-item {
        padding: 8px 0;
        border-bottom: 1px solid #e5e7eb;
      }
      .athlete-item:last-child { border-bottom: 0; }
      .athlete-name {
        font-weight: 600;
      }
      .athlete-meta {
        color: #6b7280;
        font-size: 11px;
        margin-top: 3px;
      }
      .bracket-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        align-items: start;
      }
      .stage-column {
        display: flex;
        flex-direction: column;
        gap: 12px;
        justify-content: center;
      }
      .stage-card {
        border: 1px solid #111827;
        border-radius: 8px;
        padding: 10px;
        min-height: 88px;
      }
      .stage-label {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.04em;
        margin-bottom: 8px;
      }
      .fight-row {
        display: flex;
        justify-content: space-between;
        gap: 8px;
        padding: 6px 0;
        border-bottom: 1px dashed #d1d5db;
      }
      .fight-row:last-child { border-bottom: 0; }
      .placeholder {
        color: #6b7280;
        font-style: italic;
      }
      table {
        width: 100%;
        border-collapse: collapse;
      }
      th, td {
        border: 1px solid #d1d5db;
        padding: 7px;
        text-align: left;
        vertical-align: top;
      }
      th {
        background: #f3f4f6;
        font-size: 11px;
      }
      .empty {
        border: 1px dashed #9ca3af;
        border-radius: 8px;
        padding: 16px;
        text-align: center;
        color: #6b7280;
      }
      .result {
        margin-top: 6px;
        font-size: 11px;
        color: #374151;
      }
    </style>
  </head>
  <body>
    {{#if hasBrackets}}
      {{#each brackets}}
        <section class="page">
          <header class="header">
            <div class="title">{{../competitionName}}</div>
            <div class="meta">
              <div>
                <div><strong>Categoria:</strong> {{categoryName}}</div>
                <div><strong>Chave:</strong> {{bracketName}}</div>
              </div>
              <div>
                <div><strong>Modo:</strong> {{../competitionMode}}</div>
                <div><strong>Exportado em:</strong> {{../exportedAt}}</div>
              </div>
            </div>
          </header>

          <section class="summary">
            <div class="box">
              <div class="section-title">Atletas</div>
              <ul class="athlete-list">
                {{#each athletes}}
                  <li class="athlete-item">
                    <div class="athlete-name">{{fullName}}</div>
                    <div class="athlete-meta">
                      {{birthDate}} | {{belt}}{{#if academyName}} | {{academyName}}{{/if}}
                    </div>
                  </li>
                {{/each}}
              </ul>
            </div>

            <div class="box">
              <div class="section-title">Estrutura da Chave</div>
              <div class="bracket-grid">
                <div class="stage-column">
                  {{#each stage.semiFinals}}
                    <div class="stage-card">
                      <div class="stage-label">{{label}}</div>
                      <div class="fight-row">
                        <span>{{athleteA}}</span>
                        <span>vs</span>
                      </div>
                      <div class="fight-row">
                        <span>{{athleteB}}</span>
                        <span>{{#if areaName}}Área {{areaName}}{{/if}}</span>
                      </div>
                      {{#if winner}}
                        <div class="result">Vencedor: {{winner}}{{#if winType}} | {{winType}}{{/if}}</div>
                      {{else}}
                        <div class="result placeholder">Campo para preenchimento manual</div>
                      {{/if}}
                    </div>
                  {{/each}}
                </div>

                <div class="stage-column">
                  <div class="stage-card">
                    <div class="stage-label">{{stage.final.label}}</div>
                    <div class="fight-row">
                      <span>{{stage.final.athleteA}}</span>
                      <span>vs</span>
                    </div>
                    <div class="fight-row">
                      <span>{{stage.final.athleteB}}</span>
                      <span>{{#if stage.final.areaName}}Área {{stage.final.areaName}}{{/if}}</span>
                    </div>
                    {{#if stage.final.winner}}
                      <div class="result">Vencedor: {{stage.final.winner}}{{#if stage.final.winType}} | {{stage.final.winType}}{{/if}}</div>
                    {{else}}
                      <div class="result placeholder">Campo para preenchimento manual</div>
                    {{/if}}
                  </div>
                </div>
              </div>
            </div>
          </section>

          <section class="box">
            <div class="section-title">Lutas Geradas</div>
            {{#if fights.length}}
              <table>
                <thead>
                  <tr>
                    <th>Round</th>
                    <th>#</th>
                    <th>Atleta A</th>
                    <th>Atleta B</th>
                    <th>Área</th>
                    {{#if ../includeResults}}
                      <th>Vencedor</th>
                      <th>Tipo</th>
                    {{/if}}
                  </tr>
                </thead>
                <tbody>
                  {{#each fights}}
                    <tr>
                      <td>{{round}}</td>
                      <td>{{fightNumber}}</td>
                      <td>{{athleteA}}{{#if academyA}}<br />{{academyA}}{{/if}}</td>
                      <td>{{athleteB}}{{#if academyB}}<br />{{academyB}}{{/if}}</td>
                      <td>{{areaName}}</td>
                      {{#if ../../includeResults}}
                        <td>{{winner}}</td>
                        <td>{{winType}}</td>
                      {{/if}}
                    </tr>
                  {{/each}}
                </tbody>
              </table>
            {{else}}
              <div class="empty">Nenhuma luta gerada para esta chave.</div>
            {{/if}}
          </section>
        </section>
      {{/each}}
    {{else}}
      <section class="page">
        <header class="header">
          <div class="title">{{competitionName}}</div>
          <div class="meta">
            <div><strong>Modo:</strong> {{competitionMode}}</div>
            <div><strong>Exportado em:</strong> {{exportedAt}}</div>
          </div>
        </header>
        <div class="empty">Nenhuma chave encontrada para os filtros informados.</div>
      </section>
    {{/if}}
  </body>
  </html>
